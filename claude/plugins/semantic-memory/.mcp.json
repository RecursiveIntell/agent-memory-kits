{
  "mcpServers": {
    "semantic-memory": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-server.sh",
      "env": {
        "SEMANTIC_MEMORY_DIR": "${HOME}/.hermes/semantic-memory.db",
        "SEMANTIC_MEMORY_TOOL_PROFILE": "agent",
        "SEMANTIC_MEMORY_HTTP_PORT": "1739",
        "SEMANTIC_MEMORY_EMBEDDER": "candle"
      }
    },
    "semantic-memory-admin": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/run-server-admin.sh",
      "env": {
        "SEMANTIC_MEMORY_DIR": "${HOME}/.hermes/semantic-memory.db",
        "SEMANTIC_MEMORY_ADMIN_TOOL_PROFILE": "full",
        "SEMANTIC_MEMORY_ADMIN_HTTP_PORT": "0",
        "SEMANTIC_MEMORY_EMBEDDER": "candle"
      }
    },
    "context-governor": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/context-governor-mcp.py",
      "env": {
        "CONTEXT_GOVERNOR_STORE": "${HOME}/.hermes/context-governor"
      }
    },
    "claim-ledger": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/claim-ledger-mcp.py"
    }
  }
}
