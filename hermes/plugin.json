{
  "name": "semantic-memory",
  "version": "0.6.0",
  "description": "Local-first knowledge base with hybrid search, knowledge graphs, and autonomous memory lifecycle \u2014 for Hermes Agent",
  "author": "RecursiveIntell",
  "license": "Apache-2.0",
  "hermes": {
    "skills": [
      "memory-capture",
      "memory-curator",
      "memory-maintenance",
      "memory-sync",
      "knowledge-graph-explorer",
      "release-gate",
      "context-compaction",
      "claim-provenance",
      "llm-output-parsing"
    ],
    "agents": [
      "memory-keeper"
    ],
    "hooks": {
      "on_session_start": "scripts/sm-primer.sh",
      "pre_llm_call": "hooks/sm-recall.py",
      "post_tool_use": "hooks/sm-auto-edge.sh",
      "post_llm_call": "hooks/sm-conversation-capture.py"
    },
    "commands": {
      "/memory-setup": "commands/memory-setup.md",
      "/memory-ingest": "commands/memory-ingest.md",
      "/memory-gaps": "commands/memory-gaps.md",
      "/evidence-workbench": "commands/evidence-workbench.md",
      "/proof-packet": "commands/proof-packet.md"
    },
    "mcp_servers": {
      "semantic-memory": {
        "command": "semantic-memory-mcp",
        "args": [
          "--memory-dir",
          "$SEMANTIC_MEMORY_DIR",
          "--tool-profile",
          "agent",
          "--http-port",
          "1739"
        ]
      },
      "context-governor": {
        "command": "python3",
        "args": [
          "scripts/context-governor-mcp.py"
        ]
      },
      "claim-ledger": {
        "command": "python3",
        "args": [
          "scripts/claim-ledger-mcp.py"
        ]
      },
      "semantic-memory-admin": {
        "command": "bash",
        "args": [
          "scripts/run-server-admin.sh"
        ]
      },
      "forge-admin": {
        "command": "python3",
        "args": [
          "scripts/forge-admin-mcp.py"
        ]
      }
    }
  }
}
