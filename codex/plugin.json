{
  "name": "semantic-memory",
  "version": "0.6.0",
  "description": "Local-first knowledge base with hybrid search, knowledge graphs, and autonomous memory lifecycle — for Codex CLI (OpenAI)",
  "author": "RecursiveIntell",
  "license": "Apache-2.0",
  "codex": {
    "skills": ["memory-capture", "memory-curator", "knowledge-graph-explorer"],
    "hooks": {
      "post_tool_use": "hooks/sm-persist.sh"
    },
    "mcp_servers": {
      "semantic-memory": {
        "command": "semantic-memory-mcp",
        "args": ["--memory-dir", "$SEMANTIC_MEMORY_DIR", "--tool-profile", "lean", "--http-port", "1738"]
      }
    }
  }
}
