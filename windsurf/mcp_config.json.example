{
  "mcpServers": {
    "semantic-memory": {
      "command": "/ABSOLUTE/PATH/TO/semantic-memory-agent-kits/windsurf/scripts/run-server.sh",
      "env": {
        "SEMANTIC_MEMORY_DIR": "${HOME}/.local/share/semantic-memory",
        "SEMANTIC_MEMORY_TOOL_PROFILE": "lean",
        "SEMANTIC_MEMORY_HTTP_PORT": "1739"
      }
    },
    "context-governor": {
      "command": "/ABSOLUTE/PATH/TO/semantic-memory-agent-kits/shared/scripts/context-governor-mcp.py",
      "env": {
        "CONTEXT_GOVERNOR_STORE": "${HOME}/.local/share/context-governor/receipts"
      }
    }
  }
}
